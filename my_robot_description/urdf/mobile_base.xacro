<?xml version="1.0"?>

<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:property name="base_length" value="0.6" />
    <xacro:property name="base_width" value="0.4" />
    <xacro:property name="base_height" value="0.2" />
    <xacro:property name="wheel_radius" value="0.1" />
    <xacro:property name="wheel_length" value="0.05" />

    <xacro:macro name="wheel_links" params="prefix">
        <link name="${prefix}_wheel">
            <visual>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_length}"/>
                </geometry>
                <origin xyz="0 0 0" rpy ="${-pi/2.0} 0 0"/>
                <material name="grey"/>
            </visual>            
            <collision>
                <geometry>
                    <sphere radius="${wheel_radius}"/>
                </geometry>
                <origin xyz="0 0 0" rpy="0 0 0"/>
            </collision>
            <xacro:cylinder-inertia m="1.0" r="${wheel_radius}" h="${wheel_length}" o_xyz="0 0 0" o_rpy="${-pi/2.0} 0 0" />
        </link>
    </xacro:macro>  

    <link name="base_link">
        <visual>
            <geometry>
                <box size="${base_length} ${base_width} ${base_height}"/>
            </geometry>
            <origin xyz="0 0 0.1" rpy="0 0 0"/>
            <material name="green"/>
        </visual>
        <collision>
            <geometry>
                <box size="${base_length} ${base_width} ${base_height}"/>
            </geometry>
            <origin xyz="0 0 0.1" rpy="0 0 0"/>
        </collision>
         <xacro:box-inertia m="5.0" x="${base_length}" y="${base_width}" z="${base_height}"
                              o_xyz = "0 0 0.1" o_rpy="0 0 0" />
    </link>

    <xacro:wheel_links prefix="right"/>
    <xacro:wheel_links prefix="left"/>

<!-- 
    <link name="right_wheel">
        <visual>
            <geometry>
                <cylinder radius="${wheel_radius}" length="${wheel_length}"/>
            </geometry>
            <origin xyz="0 0 0" rpy ="${-pi/2.0} 0 0"/>
            <material name="grey"/>
        </visual>
    </link>


    <link name="left_wheel">
        <visual>
            <geometry>
                <cylinder radius="${wheel_radius}" length="${wheel_length}"/>
            </geometry>
            <origin xyz="0 0 0" rpy="${pi/2.0} 0 0"/>
            <material name="grey"/>
        </visual>
    </link> -->


    <link name="caster_wheel">
        <visual>
            <geometry>
                <sphere radius="${wheel_radius / 2}"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <material name="grey"/>
        </visual>
        <collision>
            <geometry>
                <sphere radius="${wheel_radius / 2}"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </collision>
        <xacro:sphere-inertia m="0.5" r="${wheel_radius/2}" o_xyz="0 0 0" o_rpy="0 0 0" />
    </link>


    <link name="base footprint"/>

    <!-- joints! -->

    <joint name="base_with_rightWheel" type="continuous">
        <parent link="base_link"/>
        <child link="right_wheel"/>
        <origin xyz="${-base_length/4.0} ${-base_width/1.77} 0.0" rpy="0.0 0.0 0.0"/>
        <axis xyz="0.0 1 0.0"/>
    </joint>

    <joint name="base_with_leftWheel" type="continuous">
        <parent link="base_link"/>
        <child link="left_wheel"/>
        <origin xyz="${-base_length/4.0} ${base_width/1.77} 0.0" rpy="0.0 0.0 0.0"/>
        <axis xyz="0.0 1 0.0"/>
    </joint>

    <joint name="base_with_caster" type="fixed">
        <parent link="base_link"/>
        <child link="caster_wheel"/>
        <origin xyz="${base_length /3.0} 0.0 ${-base_height / 4.0}" rpy="0.0 0.0 0.0"/>
    </joint>

    <joint name="base_joint" type="fixed">
        <parent link="base_link"/>
        <child link="base footprint"/>
        <origin xyz="0.0 0.0 ${-base_height / 4.0}" rpy="0.0 0.0 0.0"/>
    </joint>

</robot>
